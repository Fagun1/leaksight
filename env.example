# Copy to .env and add your cloud credentials

APP_NAME=LeakSight

# MongoDB Atlas: https://cloud.mongodb.com — Create cluster → Connect → Get connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/leaksight?retryWrites=true&w=majority

# Redis Cloud: https://redis.com/try-free — Create database → Get connection URL
REDIS_URL=rediss://default:<password>@<host>:<port>

# Frontend API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Scrapers use Forums + MacRumors + NotebookCheck + TechRadar — no API keys required
